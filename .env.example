# ===========================================
# 店赢OS 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ===========================================

# ===========================================
# AI大模型配置
# ===========================================
# 选择AI渠道: ark|openai|deepseek|qwen|zhipu|moonshot|wenxin|spark|yi|minimax|baichuan|hunyuan|siliconflow|groq|xiaomi|tencent|aliyun
AI_PROVIDER=ark

# -------------------------------------------
# 火山方舟(豆包) - 字节跳动
# -------------------------------------------
ARK_API_KEY=
ARK_ENDPOINT_ID=

# -------------------------------------------
# OpenAI
# -------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# -------------------------------------------
# DeepSeek
# -------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# -------------------------------------------
# 阿里通义千问 (DashScope API Key)
# -------------------------------------------
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# -------------------------------------------
# 智谱AI (GLM)
# -------------------------------------------
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4

# -------------------------------------------
# 月之暗面(Kimi)
# -------------------------------------------
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k

# -------------------------------------------
# 百度文心一言
# -------------------------------------------
WENXIN_API_KEY=
WENXIN_MODEL=ernie-4.0-8k-latest

# -------------------------------------------
# 讯飞星火
# -------------------------------------------
SPARK_API_KEY=
SPARK_MODEL=generalv3.5

# -------------------------------------------
# 零一万物(Yi)
# -------------------------------------------
YI_API_KEY=
YI_MODEL=yi-large

# -------------------------------------------
# MiniMax
# -------------------------------------------
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat

# -------------------------------------------
# 百川智能
# -------------------------------------------
BAICHUAN_API_KEY=
BAICHUAN_MODEL=Baichuan4

# -------------------------------------------
# 腾讯混元 (私有部署版)
# -------------------------------------------
HUNYUAN_API_KEY=
HUNYUAN_MODEL=hunyuan-pro

# -------------------------------------------
# 硅基流动 (SiliconFlow)
# -------------------------------------------
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# -------------------------------------------
# Groq
# -------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# -------------------------------------------
# 小米大模型 (MiLM)
# -------------------------------------------
XIAOMI_API_KEY=
XIAOMI_MODEL=mi-lm-70b

# -------------------------------------------
# 腾讯云混元 (API版)
# -------------------------------------------
TENCENT_API_KEY=
TENCENT_MODEL=hunyuan-lite

# -------------------------------------------
# 阿里云百炼 (AccessKey)
# 注意：与通义千问QWEN_共用base_url，但使用阿里云AccessKey认证
# -------------------------------------------
ALIYUN_API_KEY=
ALIYUN_MODEL=qwen-turbo

# ===========================================
# 天阙支付配置
# ===========================================
TIANQUE_ORG_ID=
TIANQUE_PRIVATE_KEY=
TIANQUE_PUBLIC_KEY=
TIANQUE_SP_PUBLIC_KEY=
TIANQUE_MERCHANT_NO=

# ===========================================
# 其他配置
# ===========================================
# API服务端口
# PORT=8080

# 调试模式
# DEBUG=false
